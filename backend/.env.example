# ── OCR backend ──────────────────────────────────────────────────────────────
# "easyocr"  = local model, no extra setup (default)
# "ollama"   = local Ollama vision model (much higher accuracy)
OCR_BACKEND=easyocr

# Ollama settings — only used when OCR_BACKEND=ollama
# Install: https://ollama.com  →  brew install ollama && ollama serve
# Pull a vision model first: ollama pull llama3.2-vision
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./chess_tourny.db
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_MB=20
